#!/usr/bin/env bash
set -euo pipefail

patterns='TurtleTerm|turtleterm|turtle-term|turtle-agentd|turtle-agentctl|turtle-tmux|sourceos-term'

echo "TurtleTerm network surface"
echo "declared default: no external egress; no non-loopback plaintext control channel"

echo
echo "observed listeners:"
if command -v lsof >/dev/null 2>&1; then
  lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null | grep -Ei "$patterns" || echo "  none"
else
  echo "  lsof unavailable"
fi

echo
echo "policy: any local gateway listener must be loopback or stdio by default and declared in TRUST_SURFACE.yaml"
