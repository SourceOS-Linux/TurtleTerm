#!/usr/bin/env bash
set -euo pipefail

patterns='TurtleTerm|turtleterm|turtle-term|turtle-agentd|turtle-agentctl|turtle-tmux|sourceos-term'

echo "TurtleTerm doctor"
echo "component: TurtleTerm"
echo "trust_surface: TRUST_SURFACE.yaml"

echo
echo "commands:"
for cmd in turtleterm turtle-term turtle-agentd turtle-agentctl turtle-tmux sourceos-term; do
  if command -v "$cmd" >/dev/null 2>&1; then
    echo "  $cmd: $(command -v "$cmd")"
  else
    echo "  $cmd: missing"
  fi
done

echo
echo "processes:"
pgrep -af "$patterns" || echo "  none"

echo
echo "launch services:"
if command -v launchctl >/dev/null 2>&1; then
  launchctl list 2>/dev/null | grep -Ei "$patterns" || echo "  no launchctl entries"
fi
find "$HOME/Library/LaunchAgents" /Library/LaunchAgents /Library/LaunchDaemons -type f 2>/dev/null | grep -Ei "$patterns" || echo "  no launchd plist files"

echo
echo "listeners:"
if command -v lsof >/dev/null 2>&1; then
  lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null | grep -Ei "$patterns" || echo "  no TurtleTerm listeners"
else
  echo "  lsof unavailable"
fi

echo
echo "state paths:"
for p in "$HOME/.local/state/turtleterm" "$HOME/.config/turtleterm" "$HOME/.cache/turtleterm" "$HOME/Library/Logs/TurtleTerm"; do
  if [ -e "$p" ]; then
    echo "  exists: $p"
  else
    echo "  missing: $p"
  fi
done
