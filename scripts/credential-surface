#!/usr/bin/env bash
set -euo pipefail

echo "TurtleTerm credential surface"
echo "expected secrets: none currently declared"
echo "redaction: required"
echo "inherits_ssh_agent: false by default"

echo
echo "configured credential-adjacent paths:"
for p in "$HOME/.config/turtleterm" "$HOME/.local/state/turtleterm"; do
  if [ -e "$p" ]; then
    echo "  exists: $p"
    find "$p" -maxdepth 2 -type f 2>/dev/null | sed 's#^#    file: #' | sed -E 's/(token|key|secret|password|auth|ssh)/<redacted-name>/Ig'
  else
    echo "  missing: $p"
  fi
done

echo
echo "policy: do not print secret values; declare any future SSH-agent, OAuth, keychain, model-provider, or API-key authority in TRUST_SURFACE.yaml"
