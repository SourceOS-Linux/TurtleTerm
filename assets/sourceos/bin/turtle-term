#!/usr/bin/env python3
"""TurtleTerm launcher.

TurtleTerm is the SourceOS agent-aware terminal workbench product. The v0
implementation delegates to the shared SourceOS terminal wrapper while the
internal event and receipt schemas remain namespaced as `sourceos.*`.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path


if __name__ == "__main__":
    os.environ.setdefault("SOURCEOS_TERMINAL_CLI", "turtle-term")
    os.environ.setdefault("SOURCEOS_TERMINAL_FRONTEND", "turtle-term")
    target = Path(__file__).with_name("sourceos-term")
    os.execv(sys.executable, [sys.executable, str(target), *sys.argv[1:]])
