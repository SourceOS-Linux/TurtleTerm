#!/usr/bin/env python3
"""TurtleTerm launcher alias.

TurtleTerm is the SourceOS agent-aware terminal workbench product. The v0
implementation delegates to the existing SourceOS terminal wrapper while the
internal contract namespace remains `sourceos.*`.
"""

from __future__ import annotations

import runpy
from pathlib import Path


if __name__ == "__main__":
    runpy.run_path(str(Path(__file__).with_name("sourceos-term")), run_name="__main__")
