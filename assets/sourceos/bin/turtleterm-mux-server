#!/usr/bin/env sh
# TurtleTerm mux server launcher.
set -eu

bin_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

export SOURCEOS_TERMINAL_FRONTEND="${SOURCEOS_TERMINAL_FRONTEND:-turtle-term}"

try_exec() {
  candidate="$1"
  shift
  if [ -x "$candidate" ]; then
    exec "$candidate" "$@"
  fi
}

if [ -n "${TURTLE_TERM_RUNTIME_DIR:-}" ]; then
  try_exec "$TURTLE_TERM_RUNTIME_DIR/wezterm-mux-server" "$@"
fi

try_exec "${bin_dir}/../libexec/turtle-term/wezterm-mux-server" "$@"
try_exec "${bin_dir}/../opt/turtle-term/libexec/turtle-term/wezterm-mux-server" "$@"
try_exec "${bin_dir}/../Cellar/turtle-term/HEAD/libexec/turtle-term/wezterm-mux-server" "$@"

exec wezterm-mux-server "$@"
