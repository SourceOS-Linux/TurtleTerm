#!/usr/bin/env sh
# TurtleTerm Superconscious bridge.
set -eu

cmd="${1:-observe}"
case "$cmd" in
  observe)
    shift || true
    exec turtle-agentctl --stdio superconscious-observe "$@"
    ;;
  propose)
    shift || true
    exec turtle-agentctl --stdio superconscious-propose "$@"
    ;;
  *)
    echo "usage: turtle-superconscious [observe <text>|propose <prompt>]" >&2
    exit 2
    ;;
esac
