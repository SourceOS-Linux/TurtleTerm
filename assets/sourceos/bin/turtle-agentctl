#!/usr/bin/env python3
"""TurtleTerm agent gateway CLI v0."""

from __future__ import annotations

import argparse
import json
import os
import socket
import subprocess
import sys
from pathlib import Path
from typing import Any


def env(name: str, fallback: str = "") -> str:
    value = os.environ.get(name)
    return value if value else fallback


def runtime_dir() -> Path:
    return Path(env("XDG_RUNTIME_DIR", f"/tmp/sourceos-runtime-{os.getuid()}")) / "sourceos" / "turtle-term"


def socket_path() -> Path:
    return Path(env("TURTLE_AGENTD_SOCKET", str(runtime_dir() / "agentd.sock")))


def agentd_path() -> Path:
    return Path(__file__).with_name("turtle-agentd")


def request_via_socket(request: dict[str, Any]) -> dict[str, Any]:
    path = socket_path()
    if not path.exists():
        raise FileNotFoundError(f"turtle-agentd socket not found: {path}")
    client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        client.connect(str(path))
        client.sendall(json.dumps(request).encode("utf-8"))
        chunks: list[bytes] = []
        while True:
            chunk = client.recv(1024 * 1024)
            if not chunk:
                break
            chunks.append(chunk)
        return json.loads(b"".join(chunks).decode("utf-8"))
    finally:
        client.close()


def request_via_stdio(request: dict[str, Any]) -> dict[str, Any]:
    result = subprocess.run(
        [sys.executable, str(agentd_path()), "--stdio"],
        input=json.dumps(request),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if result.returncode != 0:
        raise RuntimeError(result.stderr or result.stdout)
    return json.loads(result.stdout)


def send_request(request: dict[str, Any], use_stdio: bool) -> dict[str, Any]:
    if use_stdio:
        return request_via_stdio(request)
    try:
        return request_via_socket(request)
    except FileNotFoundError:
        return request_via_stdio(request)


def print_json(payload: dict[str, Any]) -> int:
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


def join_remainder(values: list[str]) -> str:
    return " ".join(values).strip()


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="TurtleTerm agent gateway CLI v0")
    parser.add_argument("--stdio", action="store_true", help="bypass socket and invoke turtle-agentd --stdio")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("ping")
    sub.add_parser("sessions")
    sub.add_parser("surfaces")

    inspect_surface_p = sub.add_parser("inspect-surface")
    inspect_surface_p.add_argument("surface_id")

    surface_exec_p = sub.add_parser("request-surface-execution")
    surface_exec_p.add_argument("surface_id")
    surface_exec_p.add_argument("cmd", nargs=argparse.REMAINDER)

    inspect_p = sub.add_parser("inspect")
    inspect_p.add_argument("session_id", nargs="?")

    summarize_p = sub.add_parser("summarize")
    summarize_p.add_argument("session_id", nargs="?")

    propose_p = sub.add_parser("propose")
    propose_p.add_argument("cmd", nargs=argparse.REMAINDER)

    exec_p = sub.add_parser("request-execution")
    exec_p.add_argument("cmd", nargs=argparse.REMAINDER)

    receipts_p = sub.add_parser("receipts")
    receipts_p.add_argument("session_id", nargs="?")

    promote_p = sub.add_parser("promote-agentplane-bundle")
    promote_p.add_argument("session_id", nargs="?")

    super_obs_p = sub.add_parser("superconscious-observe")
    super_obs_p.add_argument("observation", nargs=argparse.REMAINDER)

    super_prop_p = sub.add_parser("superconscious-propose")
    super_prop_p.add_argument("prompt", nargs=argparse.REMAINDER)

    sub.add_parser("agent-machine-surfaces")
    sub.add_parser("agent-machine-probe")

    sub.add_parser("cloudfog-surfaces")
    cloudfog_inspect_p = sub.add_parser("cloudfog-inspect")
    cloudfog_inspect_p.add_argument("surface_id", nargs="?", default="cloudfog/local-devshell")

    args = parser.parse_args(argv)

    if args.command == "ping":
        request = {"action": "ping"}
    elif args.command == "sessions":
        request = {"action": "sessions"}
    elif args.command == "surfaces":
        request = {"action": "surfaces"}
    elif args.command == "inspect-surface":
        request = {"action": "inspect_surface", "surface_id": args.surface_id}
    elif args.command == "request-surface-execution":
        request = {"action": "request_surface_execution", "surface_id": args.surface_id, "command": join_remainder(args.cmd)}
    elif args.command == "inspect":
        request = {"action": "inspect", "session_id": args.session_id}
    elif args.command == "summarize":
        request = {"action": "summarize", "session_id": args.session_id}
    elif args.command == "propose":
        request = {"action": "propose_command", "command": join_remainder(args.cmd)}
    elif args.command == "request-execution":
        request = {"action": "request_execution", "command": join_remainder(args.cmd)}
    elif args.command == "receipts":
        request = {"action": "receipts", "session_id": args.session_id}
    elif args.command == "promote-agentplane-bundle":
        request = {"action": "promote_agentplane_bundle", "session_id": args.session_id}
    elif args.command == "superconscious-observe":
        request = {"action": "superconscious_observe", "observation": {"text": join_remainder(args.observation)}}
    elif args.command == "superconscious-propose":
        request = {"action": "superconscious_propose", "prompt": join_remainder(args.prompt)}
    elif args.command == "agent-machine-surfaces":
        request = {"action": "agent_machine_surfaces"}
    elif args.command == "agent-machine-probe":
        request = {"action": "agent_machine_probe"}
    elif args.command == "cloudfog-surfaces":
        request = {"action": "cloudfog_surfaces"}
    elif args.command == "cloudfog-inspect":
        request = {"action": "cloudfog_inspect", "surface_id": args.surface_id}
    else:
        parser.print_help(sys.stderr)
        return 2

    return print_json(send_request(request, args.stdio))


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
