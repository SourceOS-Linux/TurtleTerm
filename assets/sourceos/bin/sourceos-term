#!/usr/bin/env python3
"""TurtleTerm / SourceOS terminal command wrapper v0.

Runs a command, mirrors stdout/stderr to the active terminal, and emits
SourceOS terminal command lifecycle events plus a durable command receipt.

`turtle-term` is the product CLI. `sourceos-term` remains as a compatibility
entrypoint for SourceOS contract work. The event and receipt schemas remain
namespaced as `sourceos.*` because they are platform contracts.
"""

from __future__ import annotations

import argparse
import datetime as _dt
import hashlib
import json
import os
import selectors
import shlex
import socket
import subprocess
import sys
import uuid
from pathlib import Path
from typing import Any, Iterable


SESSION_SCHEMA = "sourceos.terminal.session.v0"
EVENT_SCHEMA = "sourceos.terminal.event.v0"
RECEIPT_SCHEMA = "sourceos.terminal.receipt.v0"
OFFICE_OPERATOR_PLAN_SCHEMA = "sourceos.turtleterm.office.operator_plan.v0"
OFFICE_EVIDENCE_SUMMARY_SCHEMA = "sourceos.turtleterm.office.evidence_summary.v0"

OFFICE_RUNTIME_CONTRACT_SCHEMAS = {
    "officeDocumentRecord": "https://socioprophet.dev/schemas/office/office_document_record.schema.json",
    "officeSessionRecord": "https://socioprophet.dev/schemas/office/office_session_record.schema.json",
    "officeVersionRecord": "https://socioprophet.dev/schemas/office/office_version_record.schema.json",
    "officeWritebackRecord": "https://socioprophet.dev/schemas/office/office_writeback_record.schema.json",
}


def env(name: str, fallback: str = "") -> str:
    value = os.environ.get(name)
    if value is None or value == "":
        return fallback
    return value


def invoked_name() -> str:
    return Path(sys.argv[0]).name or "turtle-term"


def product_name() -> str:
    explicit = env("SOURCEOS_TERMINAL_CLI")
    if explicit in {"turtle-term", "sourceos-term"}:
        return explicit
    name = invoked_name()
    if name == "sourceos-term":
        return "sourceos-term"
    return "turtle-term"


def default_session_prefix() -> str:
    if product_name() == "sourceos-term":
        return "sourceos-term"
    return "turtle-term"


def utc_now() -> str:
    return _dt.datetime.now(tz=_dt.timezone.utc).isoformat().replace("+00:00", "Z")


def new_id(prefix: str) -> str:
    return f"{prefix}_{uuid.uuid4().hex}"


def xdg_runtime_dir() -> Path:
    return Path(env("XDG_RUNTIME_DIR", f"/tmp/sourceos-runtime-{os.getuid()}"))


def xdg_state_home() -> Path:
    return Path(env("XDG_STATE_HOME", str(Path.home() / ".local" / "state")))


def events_path() -> Path:
    return Path(env("SOURCEOS_TERMINAL_EVENTS", str(xdg_runtime_dir() / "sourceos" / "terminal" / "events.ndjson")))


def receipts_dir(session_id: str) -> Path:
    base = Path(env("SOURCEOS_TERMINAL_RECEIPTS", str(xdg_state_home() / "sourceos" / "terminal" / "receipts")))
    return base / session_id


def append_event(event: dict[str, Any]) -> None:
    path = events_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(event, sort_keys=True, separators=(",", ":")))
        handle.write("\n")


def write_receipt(session_id: str, event_id: str, receipt: dict[str, Any]) -> Path:
    directory = receipts_dir(session_id)
    directory.mkdir(parents=True, exist_ok=True)
    path = directory / f"{event_id}.json"
    tmp_path = path.with_suffix(".json.tmp")
    tmp_path.write_text(json.dumps(receipt, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    tmp_path.replace(path)
    return path


def run_git(args: Iterable[str]) -> str:
    try:
        result = subprocess.run(
            ["git", *args],
            cwd=os.getcwd(),
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=2,
            check=False,
        )
    except Exception:
        return ""
    if result.returncode != 0:
        return ""
    return result.stdout.strip()


def detect_repo_root() -> str:
    return run_git(["rev-parse", "--show-toplevel"])


def detect_git_branch() -> str:
    branch = run_git(["branch", "--show-current"])
    if branch:
        return branch
    return run_git(["rev-parse", "--short", "HEAD"])


def detect_execution_domain() -> str:
    explicit = env("SOURCEOS_EXECUTION_DOMAIN")
    if explicit:
        return explicit
    if env("DISTROBOX_ENTER_PATH") or env("DISTROBOX_HOST_HOME"):
        return "distrobox"
    if env("TOOLBOX_PATH") or env("TOOLBOX_CONTAINER"):
        return "toolbox"
    if env("container") or Path("/.dockerenv").exists():
        return "container"
    if env("SSH_CONNECTION") or env("SSH_CLIENT"):
        return "ssh"
    return "host"


def build_context(command: list[str]) -> dict[str, Any]:
    session_id = env("SOURCEOS_TERMINAL_SESSION_ID", f"{default_session_prefix()}-{uuid.uuid4().hex}")
    workspace_id = env("SOURCEOS_WORKSPACE", "sourceos")
    actor_id = env("SOURCEOS_ACTOR_ID", f"human:{env('USER', 'local-user')}")
    policy_bundle_id = env("SOURCEOS_POLICY_BUNDLE_ID", "unbound")
    cwd = os.getcwd()

    return {
        "session_id": session_id,
        "workspace_id": workspace_id,
        "actor_id": actor_id,
        "policy_bundle_id": policy_bundle_id,
        "execution_domain": detect_execution_domain(),
        "cwd": cwd,
        "repo_root": detect_repo_root(),
        "git_branch": detect_git_branch(),
        "host": socket.gethostname(),
        "user": env("USER", "local-user"),
        "container_id": env("container", "") or None,
        "window_id": env("WEZTERM_WINDOW_ID", "unknown"),
        "tab_id": env("WEZTERM_TAB_ID", "unknown"),
        "pane_id": env("WEZTERM_PANE", env("WEZTERM_PANE_ID", "unknown")),
        "command": shlex.join(command),
        "command_argv": command,
    }


def emit_session(context: dict[str, Any], created_at: str) -> None:
    event = {
        "schema": SESSION_SCHEMA,
        "session_id": context["session_id"],
        "workspace_id": context["workspace_id"],
        "created_at": created_at,
        "actor_id": context["actor_id"],
        "frontend": env("SOURCEOS_TERMINAL_FRONTEND", product_name()),
        "frontend_version": env("SOURCEOS_TERMINAL_FRONTEND_VERSION", "unknown"),
        "execution_domain": context["execution_domain"],
        "policy_bundle_id": context["policy_bundle_id"],
    }
    append_event(event)


def event_base(context: dict[str, Any], event_type: str, event_id: str) -> dict[str, Any]:
    return {
        "schema": EVENT_SCHEMA,
        "event_type": event_type,
        "event_id": event_id,
        "session_id": context["session_id"],
        "workspace_id": context["workspace_id"],
        "window_id": context["window_id"],
        "tab_id": context["tab_id"],
        "pane_id": context["pane_id"],
        "actor_id": context["actor_id"],
        "policy_bundle_id": context["policy_bundle_id"],
        "execution_domain": context["execution_domain"],
        "cwd": context["cwd"],
        "repo_root": context["repo_root"],
        "git_branch": context["git_branch"],
        "host": context["host"],
        "user": context["user"],
        "container_id": context["container_id"],
        "command": context["command"],
        "command_argv": context["command_argv"],
    }


def stream_process(command: list[str], child_env: dict[str, str]) -> tuple[int, str, str]:
    stdout_hash = hashlib.sha256()
    stderr_hash = hashlib.sha256()

    process = subprocess.Popen(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        stdin=sys.stdin,
        env=child_env,
        bufsize=0,
    )

    assert process.stdout is not None
    assert process.stderr is not None

    selector = selectors.DefaultSelector()
    selector.register(process.stdout, selectors.EVENT_READ, "stdout")
    selector.register(process.stderr, selectors.EVENT_READ, "stderr")

    while selector.get_map():
        for key, _ in selector.select(timeout=0.1):
            stream = key.fileobj
            label = key.data
            chunk = stream.read1(8192) if hasattr(stream, "read1") else stream.read(8192)
            if not chunk:
                selector.unregister(stream)
                continue
            if label == "stdout":
                stdout_hash.update(chunk)
                sys.stdout.buffer.write(chunk)
                sys.stdout.buffer.flush()
            else:
                stderr_hash.update(chunk)
                sys.stderr.buffer.write(chunk)
                sys.stderr.buffer.flush()

        if process.poll() is not None and not selector.get_map():
            break

    returncode = process.wait()
    return returncode, f"sha256:{stdout_hash.hexdigest()}", f"sha256:{stderr_hash.hexdigest()}"


def run_command(command: list[str]) -> int:
    if not command:
        print(f"{product_name()}: no command provided", file=sys.stderr)
        return 2

    started_at = utc_now()
    context = build_context(command)
    session_created = env("SOURCEOS_TERMINAL_SESSION_CREATED_AT", started_at)
    event_started_id = new_id("evt")
    event_completed_id = new_id("evt")

    emit_session(context, session_created)

    started = event_base(context, "command.started", event_started_id)
    started["started_at"] = started_at
    append_event(started)

    child_env = dict(os.environ)
    child_env["SOURCEOS_TERMINAL_SESSION_ID"] = context["session_id"]
    child_env["SOURCEOS_WORKSPACE"] = context["workspace_id"]
    child_env["SOURCEOS_EXECUTION_DOMAIN"] = context["execution_domain"]

    try:
        exit_status, stdout_digest, stderr_digest = stream_process(command, child_env)
    except FileNotFoundError:
        exit_status = 127
        stdout_digest = "sha256:" + hashlib.sha256(b"").hexdigest()
        stderr_digest = "sha256:" + hashlib.sha256(f"command not found: {command[0]}\n".encode()).hexdigest()
        print(f"{product_name()}: command not found: {command[0]}", file=sys.stderr)
    except KeyboardInterrupt:
        exit_status = 130
        stdout_digest = "sha256:unknown"
        stderr_digest = "sha256:unknown"

    completed_at = utc_now()
    completed = event_base(context, "command.completed", event_completed_id)
    completed.update(
        {
            "exit_status": exit_status,
            "started_at": started_at,
            "completed_at": completed_at,
            "stdout_digest": stdout_digest,
            "stderr_digest": stderr_digest,
            "artifact_paths": [],
        }
    )

    receipt = {
        "schema": RECEIPT_SCHEMA,
        "receipt_id": new_id("receipt"),
        "session_id": context["session_id"],
        "workspace_id": context["workspace_id"],
        "event_id": event_completed_id,
        "actor_id": context["actor_id"],
        "requested_by": env("SOURCEOS_REQUESTED_BY", context["actor_id"]),
        "approved_by": env("SOURCEOS_APPROVED_BY", context["policy_bundle_id"]),
        "policy_bundle_id": context["policy_bundle_id"],
        "execution_domain": context["execution_domain"],
        "cwd": context["cwd"],
        "repo_root": context["repo_root"],
        "git_branch": context["git_branch"],
        "host": context["host"],
        "user": context["user"],
        "container_id": context["container_id"],
        "command": context["command"],
        "command_argv": context["command_argv"],
        "exit_status": exit_status,
        "started_at": started_at,
        "completed_at": completed_at,
        "stdout_digest": stdout_digest,
        "stderr_digest": stderr_digest,
        "artifacts": [],
        "replay": {
            "kind": "terminal-event-pointer",
            "uri": f"sourceos-terminal://{context['session_id']}/events/{event_completed_id}",
        },
    }

    receipt_path = write_receipt(context["session_id"], event_completed_id, receipt)
    completed["receipt_path"] = str(receipt_path)
    append_event(completed)

    return exit_status


def print_paths() -> int:
    session_id = env("SOURCEOS_TERMINAL_SESSION_ID", "<session-id>")
    print(json.dumps({
        "events": str(events_path()),
        "receipts": str(receipts_dir(session_id)),
    }, indent=2, sort_keys=True))
    return 0


def parse_run_command(raw: list[str]) -> list[str]:
    if raw and raw[0] == "--":
        return raw[1:]
    return raw


def office_policy() -> dict[str, Any]:
    return {
        "dryRunDefault": True,
        "mutatingExecutionRequires": ["--execute", "--policy-ok"],
        "closedProviderRuntimeAuthorityAllowed": False,
        "memoryOrSemanticMutationInHotPathAllowed": False,
        "recommendedReceiptPath": "turtle-term run -- sourceosctl office ...",
    }


def sourceosctl_office_plan_argv(args: argparse.Namespace) -> list[str]:
    if args.office_action == "evidence-inspect":
        return ["sourceosctl", "office", "evidence", "inspect", args.path]

    if args.office_action == "convert":
        command = [
            "sourceosctl",
            "office",
            "convert",
            args.input,
            "--to",
            args.to,
            "--dry-run",
            "--workroom-id",
            args.workroom_id,
            "--title",
            args.title,
            "--artifact-type",
            args.artifact_type,
            "--format",
            args.format,
            "--output-root",
            args.output_root,
        ]
    elif args.office_action == "inspect":
        command = ["sourceosctl", "office", "inspect", args.path]
    else:
        command = [
            "sourceosctl",
            "office",
            "generate",
            "--dry-run",
            "--workroom-id",
            args.workroom_id,
            "--title",
            args.title,
            "--artifact-type",
            args.artifact_type,
            "--format",
            args.format,
            "--output-root",
            args.output_root,
        ]
        if args.template:
            command.extend(["--template", args.template])
        if args.prompt_ref:
            command.extend(["--prompt-ref", args.prompt_ref])
        if args.data_ref:
            command.extend(["--data-ref", args.data_ref])

    if getattr(args, "evidence_out", None):
        command.extend(["--evidence-out", args.evidence_out])
    return command


def office_plan(args: argparse.Namespace) -> int:
    command = sourceosctl_office_plan_argv(args)
    payload = {
        "schema": OFFICE_OPERATOR_PLAN_SCHEMA,
        "kind": "TurtleTermOfficeOperatorPlan",
        "created_at": utc_now(),
        "workspace_id": env("SOURCEOS_WORKSPACE", "sourceos"),
        "actor_id": env("SOURCEOS_ACTOR_ID", f"human:{env('USER', 'local-user')}"),
        "frontend": env("SOURCEOS_TERMINAL_FRONTEND", product_name()),
        "operation": args.office_action,
        "command": shlex.join(command),
        "command_argv": command,
        "receipt_command": ["turtle-term", "run", "--", *command],
        "runtime_contract_schemas": OFFICE_RUNTIME_CONTRACT_SCHEMAS,
        "expected_runtime_contracts": [
            "officeDocumentRecord",
            "officeSessionRecord",
            "officeVersionRecord",
            "officeWritebackRecord",
        ] if args.office_action in {"generate", "convert"} else [],
        "policy": office_policy(),
    }
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


def office_evidence_summary(args: argparse.Namespace) -> int:
    path = Path(args.path)
    if not path.exists() or not path.is_file():
        print(f"{product_name()}: office evidence not found: {path}", file=sys.stderr)
        return 1
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        print(f"{product_name()}: invalid office evidence JSON: {exc}", file=sys.stderr)
        return 1

    runtime_contracts = payload.get("officeRuntimeContracts", {}) if isinstance(payload, dict) else {}
    version = runtime_contracts.get("officeVersionRecord", {}) if isinstance(runtime_contracts, dict) else {}
    writeback = runtime_contracts.get("officeWritebackRecord", {}) if isinstance(runtime_contracts, dict) else {}
    document = runtime_contracts.get("officeDocumentRecord", {}) if isinstance(runtime_contracts, dict) else {}

    summary = {
        "schema": OFFICE_EVIDENCE_SUMMARY_SCHEMA,
        "kind": "TurtleTermOfficeEvidenceSummary",
        "path": str(path),
        "evidence_kind": payload.get("kind") if isinstance(payload, dict) else None,
        "artifact_id": payload.get("artifactId") if isinstance(payload, dict) else None,
        "workroom_id": payload.get("workroomId") if isinstance(payload, dict) else None,
        "format": payload.get("format") if isinstance(payload, dict) else None,
        "operation": payload.get("operation") if isinstance(payload, dict) else None,
        "status": payload.get("status") if isinstance(payload, dict) else None,
        "runtime_contract_kinds": sorted(runtime_contracts.keys()) if isinstance(runtime_contracts, dict) else [],
        "office_document_id": document.get("document_id") if isinstance(document, dict) else None,
        "office_version_id": version.get("version_id") if isinstance(version, dict) else None,
        "office_writeback_id": writeback.get("writeback_id") if isinstance(writeback, dict) else None,
        "content_hash": version.get("content_hash") if isinstance(version, dict) else None,
        "policy": office_policy(),
    }
    print(json.dumps(summary, indent=2, sort_keys=True))
    return 0


def add_office_common(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--workroom-id", default="workroom-local-default", help="Professional Workroom id")
    parser.add_argument("--title", default="Untitled Office Artifact", help="Office artifact title")
    parser.add_argument("--artifact-type", default="document", help="Office artifact type")
    parser.add_argument("--format", default="md", help="Office artifact format")
    parser.add_argument("--output-root", default="~/Documents/SourceOS/agent-output", help="Host Office output root")
    parser.add_argument("--evidence-out", default=None, help="Optional OfficeArtifactEvidence output path")


def normalize_argv(argv: list[str]) -> list[str]:
    if argv and argv[0] == "/office":
        return ["office", *argv[1:]]
    return argv


def main(argv: list[str]) -> int:
    argv = normalize_argv(argv)
    if argv and argv[0] not in {"run", "paths", "office", "-h", "--help"}:
        return run_command(parse_run_command(argv))

    parser = argparse.ArgumentParser(description="TurtleTerm command wrapper v0")
    subparsers = parser.add_subparsers(dest="command_name")

    run_parser = subparsers.add_parser("run", help="run a command and emit SourceOS terminal events")
    run_parser.add_argument("cmd", nargs=argparse.REMAINDER)

    subparsers.add_parser("paths", help="print event and receipt paths")

    office_parser = subparsers.add_parser("office", help="plan and inspect SourceOS Office operator flows")
    office_sub = office_parser.add_subparsers(dest="office_command")

    office_plan_parser = office_sub.add_parser("plan", help="render a sourceosctl office operator plan")
    office_plan_parser.add_argument("--office-action", default="generate", choices=["generate", "convert", "inspect", "evidence-inspect"], help="Office action to plan")
    add_office_common(office_plan_parser)
    office_plan_parser.add_argument("--template", default=None, help="Optional SourceOS office template reference")
    office_plan_parser.add_argument("--prompt-ref", default=None, help="Optional prompt/context reference")
    office_plan_parser.add_argument("--data-ref", default=None, help="Optional structured data reference")
    office_plan_parser.add_argument("--input", default="./input.docx", help="Input path for convert action")
    office_plan_parser.add_argument("--to", default="pdf", help="Target format for convert action")
    office_plan_parser.add_argument("--path", default="./office-evidence.json", help="Path for inspect/evidence-inspect actions")
    office_plan_parser.set_defaults(func=office_plan)

    evidence_parser = office_sub.add_parser("evidence", help="inspect SourceOS Office evidence")
    evidence_sub = evidence_parser.add_subparsers(dest="office_evidence_command")
    evidence_inspect = evidence_sub.add_parser("inspect", help="summarize OfficeArtifactEvidence runtime contract ids")
    evidence_inspect.add_argument("path", help="Path to OfficeArtifactEvidence JSON")
    evidence_inspect.set_defaults(func=office_evidence_summary)

    args = parser.parse_args(argv)

    if args.command_name == "paths":
        return print_paths()

    if args.command_name == "run":
        return run_command(parse_run_command(args.cmd))

    if args.command_name == "office" and hasattr(args, "func"):
        return args.func(args)

    parser.print_help(sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
